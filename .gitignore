```gitignore
# ==============================
# Dependencies
# ==============================
node_modules/
**/node_modules/

# ==============================
# Environment variables
# ==============================
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ==============================
# Build output
# ==============================
dist/
build/
out/
.next/
coverage/

**/dist/
**/build/
**/out/
**/coverage/

# ==============================
# NestJS
# ==============================
backend/dist/
backend/coverage/

# ==============================
# React + Vite
# ==============================
frontend/dist/
frontend/.vite/

# ==============================
# Logs
# ==============================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================
# Runtime files
# ==============================
*.pid
*.pid.lock
pids/

# ==============================
# Cache
# ==============================
.cache/
.temp/
tmp/
.temp/
.eslintcache
*.tsbuildinfo

# ==============================
# Test output
# ==============================
coverage/
.nyc_output/

# ==============================
# Upload files
# Không dùng nếu upload Cloudinary
# ==============================
uploads/
backend/uploads/

# ==============================
# IDE
# ==============================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~

# Cho phép chia sẻ cấu hình VS Code cần thiết
!.vscode/settings.json
!.vscode/extensions.json

# ==============================
# Operating system
# ==============================
.DS_Store
Thumbs.db
Desktop.ini

# ==============================
# Package manager cache
# ==============================
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
.yarn/install-state.gz

# ==============================
# Local database files
# ==============================
data/
mongodb-data/

# ==============================
# Docker local overrides
# ==============================
docker-compose.override.yml

# ==============================
# Cloudinary / Firebase credentials
# ==============================
service-account.json
credentials.json
*.pem
*.key

# ==============================
# Miscellaneous
# ==============================
*.local
```
